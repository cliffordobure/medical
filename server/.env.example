PORT=5000
# 0.0.0.0 = accept emulator (10.0.2.2) + other devices on your network
LISTEN_HOST=0.0.0.0
MONGODB_URI=mongodb://127.0.0.1:27017/medical_students
JWT_SECRET=change-this-to-a-long-random-string
CLIENT_ORIGIN=http://localhost:5173
# Use * for development so Flutter / other devices can call the API
# CORS_ORIGIN=*

# First admin (created or promoted on startup — see seed.js)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!

# Paystack (https://dashboard.paystack.com/#/settings/developer)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxx

# Must match the public URL where this API is reachable (PDF/audio links, Paystack callback).
API_PUBLIC_URL=http://localhost:5000

# disk | gridfs | cloudinary — value is trimmed and lowercased. On Render, set cloudinary + vars below, redeploy, then re-upload each topic in admin (old rows keep disk/gridfs fields only).
UPLOAD_DRIVER=disk

# Required when UPLOAD_DRIVER=cloudinary (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
