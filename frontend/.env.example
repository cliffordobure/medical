# Deployed Express API (no trailing slash). When set, the app calls this directly (CORS must allow your web origin).
# Leave empty for local dev: requests use /api and Vite proxies to VITE_DEV_PROXY_TARGET.
# VITE_API_URL=https://your-api.example.com

# Where Vite sends /api and /uploads when VITE_API_URL is empty (local backend).
# VITE_DEV_PROXY_TARGET=http://localhost:5000
